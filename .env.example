# Copy this file to .env (or export these directly) before running the real pipeline.

# Free — get from https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=

# Optional — only needed for real speaker diarization via pyannote.audio.
# Free — get from https://huggingface.co/settings/tokens after accepting
# terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# If left blank, the pipeline automatically falls back to the pause-based
# heuristic diarization method (see src/transcribe.py).
HF_TOKEN=

# tiny | base | small | medium | large-v3  (bigger = more accurate, slower)
WHISPER_MODEL_SIZE=small
